# Ayu — fish syntax colors
# Works on both light and dark backgrounds
# Colors from https://github.com/ayu-theme/ayu-colors

set -U fish_color_normal brblack
set -U fish_color_command 399ee6
set -U fish_color_param a37acc
set -U fish_color_option f29718
set -U fish_color_keyword f29718
set -U fish_color_quote 86b300
set -U fish_color_redirection a37acc
set -U fish_color_end 828c9a
set -U fish_color_comment 828c9a
set -U fish_color_error e65050
set -U fish_color_operator 4cbf99
set -U fish_color_escape a37acc
set -U fish_color_autosuggestion 828c9a
set -U fish_color_valid_path --underline
set -U fish_color_cancel -r
set -U fish_color_search_match bryellow --background=brblack
set -U fish_color_selection white --bold --background=brblack
