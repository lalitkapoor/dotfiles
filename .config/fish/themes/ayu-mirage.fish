# Ayu Mirage — fish syntax colors
# Colors from https://github.com/ayu-theme/ayu-colors
# TODO: tune these for dark background

set -U fish_color_normal cccac2
set -U fish_color_command 73d0ff
set -U fish_color_param d4bfff
set -U fish_color_option ffad66
set -U fish_color_keyword ffad66
set -U fish_color_quote bae67e
set -U fish_color_redirection d4bfff
set -U fish_color_end cccac2
set -U fish_color_comment 5c6773
set -U fish_color_error ff3333
set -U fish_color_operator 95e6cb
set -U fish_color_escape d4bfff
